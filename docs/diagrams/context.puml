@startuml context
!theme plain
skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 13
}
skinparam actor {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}
skinparam database {
    BackgroundColor #FFF9C4
    BorderColor #F57F17
}
skinparam ArrowColor #455A64
skinparam defaultFontName Arial

title Контекстная диаграмма\nЦифровой двойник медицинского регистратора

actor "Пациент" as P

rectangle "Цифровой двойник\nмедицинского регистратора" as SYS #BBDEFB

rectangle "InsuranceServer\n(проверка полисов ОМС)\nlocalhost:8181" as INS_SRV #E8F5E9
rectangle "Служба скорой\nпомощи (103)" as EMG #FFEBEE
rectangle "Сервис записи\nврачей (заглушка)" as SCH #E8F5E9
rectangle "Страховая\nкомпания (заглушка)" as INS
rectangle "Платёжная\nсистема (заглушка)" as PAY

database "SQLite БД\nmed_registrator.db" as DB #FFF9C4

P --> SYS : Анкета\n(ФИО, полис ОМС,\nвозраст, симптомы)
SYS --> P : Талон (TXT)\n🔴🟡🟢

SYS --> INS_SRV : GET /check?policy=XXXXXXXXXXXXXXXX
INS_SRV --> SYS : {valid: true/false}

SYS --> EMG : Запрос вызова\n[КРАСНЫЙ приоритет]
EMG --> SYS : Подтверждение + ETA

SYS --> SCH : Запрос слота\n[ЖЁЛТЫЙ / ЗЕЛЁНЫЙ]
SCH --> SYS : Врач, кабинет,\nвремя приёма

SYS --> INS : Данные об обращении
SYS --> PAY : Запрос оплаты\n(заглушка)

SYS --> DB : Сохранение анкеты,\nобращения, талона
DB --> SYS : История обращений,\nстатистика по периодам
@enduml