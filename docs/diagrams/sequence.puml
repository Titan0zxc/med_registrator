@startuml sequence
!theme plain
skinparam defaultFontName Arial
title Диаграмма последовательности — обработка обращения

actor Пациент
participant MainController
participant Pipeline
participant InsuranceServer
participant DatabaseManager
participant TicketController

Пациент -> MainController : onSubmit(fullName, policy, symptoms)
MainController -> Pipeline : run(questionnaire)
activate Pipeline
Pipeline -> Pipeline : ValidationFilter.process()
Pipeline -> InsuranceServer : GET /check?policy=XXXXXXX
InsuranceServer --> Pipeline : {valid: true/false}
alt valid = false
  Pipeline --> MainController : Result.error()
  MainController --> Пациент : сообщение об ошибке
else valid = true
  Pipeline -> Pipeline : ClassificationFilter.process()
  Pipeline -> DatabaseManager : saveQuestionnaire()
  Pipeline -> DatabaseManager : saveAppeal()
  Pipeline -> DatabaseManager : saveTicket()
  Pipeline --> MainController : Result.success(ticket)
  deactivate Pipeline
  MainController -> TicketController : showTicket(ticket)
  TicketController --> Пациент : отображение талона
  Пациент -> TicketController : onSave()
  TicketController --> Пациент : сохранение TXT-файла
end
@enduml